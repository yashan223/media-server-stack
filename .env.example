# ──────────────────────────────────────────────
#  Media Server Stack — Environment Config
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ──────────────────────────────────────────────

# Service ports (host-side)
JELLYFIN_PORT=4096
QBIT_PORT=4080
FILEBROWSER_PORT=4085

# Media storage path on the host
MEDIA_DIR=/var/media/jellyfin

# Linux user/group IDs for file permissions
PUID=1000
PGID=1000

# Timezone (e.g. UTC, America/New_York, Europe/London)
TZ=UTC

# qBittorrent WebUI credentials
QBIT_WEBUI_USER=admin
QBIT_WEBUI_PASS=changeme12345

# FileBrowser credentials
FILEBROWSER_USER=admin
FILEBROWSER_PASS=changeme12345

# ──────────────────────────────────────────────
#  Optional — fill in to enable Nginx + SSL
#  Leave blank to skip SSL setup
# ──────────────────────────────────────────────
JELLYFIN_DOMAIN=
QBIT_DOMAIN=
FILEBROWSER_DOMAIN=
SSL_EMAIL=
