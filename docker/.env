# Environment configuration for the xoxo-media Docker stack
# Edit these values before running setup.sh

# ── Ports (host-side) ────────────────────────────────────────────────────────
JELLYFIN_PORT=4096
QBIT_PORT=4080
FILEBROWSER_PORT=4085

# ── Media paths ───────────────────────────────────────────────────────────────
MEDIA_DIR=/var/media/jellyfin

# ── User mapping (set to your VPS user's UID/GID: run `id` to check) ─────────
PUID=1000
PGID=1000
TZ=UTC

# ── qBittorrent ───────────────────────────────────────────────────────────────
QBIT_WEBUI_USER=admin
QBIT_WEBUI_PASS=adminadmin

# ── Nginx / SSL (only used if you run setup-ssl.sh) ──────────────────────────
JELLYFIN_DOMAIN=
QBIT_DOMAIN=
FILEBROWSER_DOMAIN=
SSL_EMAIL=
